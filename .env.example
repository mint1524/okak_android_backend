POSTGRES_DB=okak
POSTGRES_USER=okak
POSTGRES_PASSWORD=okak
JWT_SECRET=change-me-please-to-something-long
APP_PORT=8080

# LLM настройки. provider=mock | groq
LLM_PROVIDER=groq
LLM_API_KEY=
LLM_MODEL=llama-3.3-70b-versatile
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_SYSTEM_PROMPT=Ты дружелюбный ассистент. Отвечай по-русски, кратко и по делу.
LLM_MAX_TOKENS=2048
LLM_TEMPERATURE=0.7

# Google Play Billing (нужен для проверки покупок в продакшне)
# Создать service account в Google Play Console → Setup → API access
GOOGLE_PLAY_PACKAGE_NAME=club.okak.app
GOOGLE_PLAY_CREDENTIALS_PATH=/path/to/service-account.json

# OKAK MAIL integration for email-code registration
MAIL_SERVICE_BASE_URL=https://mail-api.example.com
MAIL_SERVICE_TOKEN=
MAIL_REQUEST_HMAC_SECRET=
MAIL_VERIFICATION_REQUIRED=true
MAIL_DEV_RETURN_CODE=false
MAIL_CODE_TTL_MINUTES=10
