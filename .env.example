POSTGRES_DB=okak
POSTGRES_USER=okak
POSTGRES_PASSWORD=okak
JWT_SECRET=change-me-please-to-something-long
APP_PORT=8080

# LLM настройки. provider=mock | groq
LLM_PROVIDER=mock
# Ключ Groq получить тут: https://console.groq.com/keys
LLM_API_KEY=
LLM_MODEL=llama-3.3-70b-versatile
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_SYSTEM_PROMPT=Ты дружелюбный ассистент. Отвечай по-русски, кратко и по делу.
LLM_MAX_TOKENS=512
LLM_TEMPERATURE=0.7
